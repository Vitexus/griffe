#!/usr/bin/make -f

PKGVER := $(shell dpkg-parsechangelog -S Version | sed 's/-[^-]*$$//')

%:
	dh $@ --with python3

override_dh_auto_build:
	pip3 download --no-deps "griffelib==$(PKGVER)" -d /tmp/griffelib-wheel
	python3 -m zipfile -e /tmp/griffelib-wheel/griffelib-$(PKGVER)-*.whl /tmp/griffelib-src/

override_dh_auto_install:
	install -d debian/python3-griffelib/usr/lib/python3/dist-packages/
	cp -r /tmp/griffelib-src/griffe debian/python3-griffelib/usr/lib/python3/dist-packages/

override_dh_auto_test:
	# Skip tests

override_dh_auto_clean:
	dh_auto_clean
	rm -rf /tmp/griffelib-wheel /tmp/griffelib-src
